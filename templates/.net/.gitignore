## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/

# User-specific files
*.user
*.userosscache
*.suo
*.sln.docstates
*.vcxproj.user
*.vscode/
.vscode/

# Rider
.idea/

# OS-generated files
.DS_Store
Thumbs.db

# ASP.NET Core secrets and logs
appsettings.Development.json
secrets.json
*.log

# IIS
*.vs/
.vs/
.vsconfig
.vscode/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
*.nuspec
project.lock.json
project.fragment.lock.json

# Publish output
publish/
wwwroot/

# Resharper
_ReSharper*/
*.DotSettings.user

# Coverage
coverage/
TestResults/
*.coverage
*.coveragexml

# Other
*.dbmdl
*.bak
*.sql

# Environment files (optional)
.env
.env.*

# Node.js and semantic-release
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.yarn-integrity

# Semantic release generated files
VERSION.txt